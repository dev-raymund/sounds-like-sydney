            "type": "button_group",
            "instructions": "Controls which embed the card/single template renders.",
            "required": 0,
            "choices": {
                "standard": "Standard",
                "audio": "Audio / Podcast",
                "video": "Video",
                "gallery": "Gallery"
            },
