            "layout": "horizontal"
        },
        {
            "key": "field_sls2026_audio_embed",
            "label": "Audio embed URL",
            "name": "audio_embed",
            "type": "url",
            "instructions": "SoundCloud / Spotify / MP3 URL. Shown when media type is Audio.",
            "required": 0,
            "conditional_logic": [
                [
                    { "field": "field_sls2026_media_type", "operator": "==", "value": "audio" }
